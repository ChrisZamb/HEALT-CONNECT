import numpy as np

n = 100  # numero di osservazioni (puoi cambiarlo)

# Variabili biometriche
battiti = np.random.normal(145, 20, n).clip(60, 200)
sonno = np.random.normal(7.0, 1.2, n).clip(3, 10)
carico = np.random.normal(300, 80, n).clip(50, 600)
riposo = np.random.randint(0, 7, n)

# (Opzionale) stampa di controllo
print("Battiti:", battiti[:5])
print("Sonno:", sonno[:5])
print("Carico:", carico[:5])
print("Riposo:", riposo[:5])